    }
    ;; Empty Receiver and Text Receivers
    var text_op = slice_hash(in_msg);
    ;; Receive "TopUp" message
    if (text_op == 0x92f4ec71b123c6e32f3132fc270db97d547fc53f2db467aeb7d5cd3c6c95808e) {
        $MasterDAO$_contract_store(($self'owner, $self'treasury, $self'fees, $self'admins, $self'collection, $self'token));
