                $global_send($SendParameters$_constructor_to_value_body(__tact_context_get_sender(), 50000000, $JettonTransfer$_store_cell($JettonTransfer$_constructor_queryId_amount_destination_responseDestination_customPayload_forwardTonAmount_forwardPayload(42, $msg'amount, $self'treasury, $self'treasury, null(), 1, __gen_slice_slice_5dcf118847f69faec2c995cb99acf92d70cfe3223342f66c96b504350c5d5b19()), begin_cell())));
