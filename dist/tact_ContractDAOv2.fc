;;
;; Type: VoteSettings
;; TLB: _ endTime:uint64 min_amount:coins quorum:uint32 = VoteSettings
;;

builder $VoteSettings$_store(builder build_0, (int, int, int) v) inline {
    var (v'endTime, v'min_amount, v'quorum) = v;
    build_0 = build_0.store_uint(v'endTime, 64);
    build_0 = build_0.store_varuint16(v'min_amount);
    build_0 = build_0.store_uint(v'quorum, 32);
    return build_0;
}

(slice, ((int, int, int))) $VoteSettings$_load(slice sc_0) inline {
    var v'endTime = sc_0~load_uint(64);
    var v'min_amount = sc_0~load_varuint16();
    var v'quorum = sc_0~load_uint(32);
    return (sc_0, (v'endTime, v'min_amount, v'quorum));
}

(int, int, int) $VoteSettings$_to_external(((int, int, int)) v) inline {
    var (v'endTime, v'min_amount, v'quorum) = v; 
    return (v'endTime, v'min_amount, v'quorum);
}

;;
;; Type: VaultInitialization
;; Header: 0xdb89bc8a
;; TLB: vault_initialization#db89bc8a queryId:uint64 admin:address = VaultInitialization
;;

builder $VaultInitialization$_store(builder build_0, (int, slice) v) inline {
    var (v'queryId, v'admin) = v;
    build_0 = store_uint(build_0, 3683237002, 32);
    build_0 = build_0.store_uint(v'queryId, 64);
    build_0 = build_0.store_slice(v'admin);
    return build_0;
}

cell $VaultInitialization$_store_cell((int, slice) v, builder b) inline {
    return $VaultInitialization$_store(b, v).end_cell();
}

((int, slice)) $VaultInitialization$_constructor_queryId_admin(int $queryId, slice $admin) inline {
    return ($queryId, $admin);
}

